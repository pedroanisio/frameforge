{
  "mcpServers": {
    "frameforge": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--group",
        "mcp",
        "--group",
        "vision",
        "--group",
        "browser",
        "python",
        "-m",
        "frameforge.mcp"
      ],
      "env": {
        "PYTHONPATH": "src:docs"
      }
    }
  }
}